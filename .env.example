# Core infrastructure
NATS_URL=nats://127.0.0.1:4222
REDIS_URL=redis://127.0.0.1:6379
PLATFORM_API_BIND=0.0.0.0:8000

# Platform API
BILLING_MODE=direct
BILLING_REQUEST_SUBJECT=billing.create_checkout
BILLING_PORTAL_REQUEST_SUBJECT=billing.create_portal_session
BILLING_CANCEL_REQUEST_SUBJECT=billing.cancel_subscription
PROVISION_REQUEST_SUBJECT=tenant.provision
PAUSE_REQUEST_SUBJECT=tenant.pause
RESUME_REQUEST_SUBJECT=tenant.resume
DELETE_REQUEST_SUBJECT=tenant.delete
DEPROVISION_REQUEST_SUBJECT=tenant.deprovision
RECONCILE_REQUEST_SUBJECT=tenant.reconcile
PUBLIC_TENANT_BASE_DOMAIN=supabase.localhost
LAGON_BASE_DOMAIN=lagon.localhost
PUBLIC_WEB_BASE_URL=http://localhost:3000
TENANT_KEY_PREFIX=tenant:
PLATFORM_ADMIN_TOKEN=dev-admin-token-change-me

# Billing service (optional Stripe)
BILLING_HTTP_ADDR=127.0.0.1:8080
BILLING_ACTIVE_SUBJECT=billing.subscription_active
BILLING_CANCELED_SUBJECT=billing.subscription_canceled
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_ID_STARTER=price_replace_me
STRIPE_PRICE_ID_PRO=price_replace_me
STRIPE_SUCCESS_URL=http://localhost:3000/dashboard/billing/success?session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3000/dashboard/billing/cancel
STRIPE_PORTAL_RETURN_URL=http://localhost:3000/dashboard

# Provisioner
PROVISION_BACKEND=docker
TENANTS_DIR=./tenants
BACKUPS_DIR=./backups
DOCKER_NETWORK=supahost
SUPABASE_VENDOR_DIR=./vendor/supabase-docker
LAGON_VENDOR_DIR=./vendor/lagon
LAGON_GIT_REF=main
# optional overrides if you prebuild Lagon images yourself
# LAGON_DASHBOARD_IMAGE=supahost-lagon-dashboard:main
# LAGON_SERVERLESS_IMAGE=supahost-lagon-serverless:main
TENANT_DASHBOARD_USERNAME=supabase

# Web UI / auth
NEXTAUTH_SECRET=dev-secret-change-me
PLATFORM_API_URL=http://localhost:8000
ADMIN_EMAIL=admin@local
ADMIN_PASSWORD=adminadmin
